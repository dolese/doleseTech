# ─────────────────────────────────────────────────────────────
# Dolese Tech — environment configuration
# Copy this file to `.env.local` and fill in what you need.
# Everything here is OPTIONAL — the app boots and the contact
# form works (leads are written to ./data/leads.jsonl) with no
# config at all.
# ─────────────────────────────────────────────────────────────

# ── Email notifications (Resend) ──────────────────────────────
# When set, new contact submissions are emailed to CONTACT_TO.
# Get a key at https://resend.com — leave blank to disable email.
RESEND_API_KEY=
# Verified sender (must be a domain/address verified in Resend).
CONTACT_FROM="Dolese Tech <hello@dolese.tech>"
# Where lead notifications are delivered.
CONTACT_TO=hello@dolese.tech

# ── Lead storage ──────────────────────────────────────────────
# Absolute or relative path for the file-based lead log.
# Defaults to ./data/leads.jsonl when unset.
LEADS_FILE=
